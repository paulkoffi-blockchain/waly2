# Configuration de l'environnement de développement Waly Platform

# URL de l'API backend (nécessaire pour le frontend)
NEXT_PUBLIC_API_URL=http://localhost:3001

# Configuration de la base de données (optionnel pour le développement)
# DATABASE_URL=mysql://user:password@localhost:3306/waly_platform

# Configuration IPFS (optionnel pour le développement)
# IPFS_GATEWAY_URL=https://gateway.pinata.cloud
# PINATA_API_KEY=votre_pinata_api_key
# PINATA_SECRET_KEY=votre_pinata_secret_key

# Configuration Blockchain (optionnel pour le développement)
# NEXT_PUBLIC_WALLET_CONNECT_PROJECT_ID=votre_project_id
# NEXT_PUBLIC_INFURA_PROJECT_ID=votre_infura_project_id

# Configuration des notifications (optionnel)
# NEXT_PUBLIC_PUSH_NOTIFICATIONS_ENABLED=true

# Mode développement
NODE_ENV=development
